# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tripnova?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace_with_another_long_random_secret

# Claude (Anthropic) API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Weather (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweathermap_key

# Travel advisories (optional, e.g. Travel-Advisory API needs no key)
